# 小尾巴 (XiaoWeiba) 环境变量配置
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入你的实际 API Key
# 3. .env 文件已被 .gitignore 排除，不会提交到版本控制

# DeepSeek API Key（推荐）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenAI API Key（备用）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub Token（可选，用于代码搜索等功能）
# GITHUB_TOKEN=ghp_your-github-token-here
