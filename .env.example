# 小尾巴 (XiaoWeiba) 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ==================== API密钥配置 ====================
# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI API Key（可选，作为备用）
OPENAI_API_KEY=sk-your-openai-api-key-here

# ==================== 长度限制配置 ====================
# 查询文本最大长度（字符），默认1000
XIAOWEIBA_MAX_QUERY_LENGTH=1000

# 选中代码最大长度（字符），默认1000
XIAOWEIBA_MAX_CODE_LENGTH=1000

# 消息最大长度（字符），默认5000
XIAOWEIBA_MAX_MESSAGE_LENGTH=5000

# 模式历史记录最大条数，默认100
XIAOWEIBA_MAX_MODE_HISTORY=100

# ==================== 时间阈值配置 ====================
# 远程时间查询阈值（小时），默认24
XIAOWEIBA_DISTANT_TEMPORAL_HOURS=24

# 专家系统检查间隔（小时），默认24
XIAOWEIBA_EXPERT_CHECK_INTERVAL_HOURS=24

# 延迟敏感场景阈值（毫秒），默认500
XIAOWEIBA_LATENCY_SENSITIVE_MS=500

# ==================== 置信度阈值配置 ====================
# 对话复杂度阈值（触发澄清），默认0.5
XIAOWEIBA_CLARIFICATION_COMPLEXITY=0.5

# 深度模式复杂度阈值，默认0.7
XIAOWEIBA_DEEP_MODE_COMPLEXITY=0.7

# 意图主导性阈值，默认0.5
XIAOWEIBA_INTENT_DOMINANCE=0.5

# 冷启动高置信度要求，默认0.7
XIAOWEIBA_COLD_START_HIGH_CONFIDENCE=0.7
