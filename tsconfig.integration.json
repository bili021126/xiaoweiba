{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out/tests",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "mocha"]
  },
  "include": [
    "tests/integration/extension.test.ts",
    "tests/integration/EpisodicMemoryDatabase.test.ts",
    "tests/integration/ExplainCodeFullStack.test.ts",
    "tests/integration/GenerateCommitFullStack.test.ts",
    "tests/integration/suite/index.ts",
    "tests/integration/runIntegrationTests.ts"
  ],
  "exclude": ["node_modules", "out", "tests/integration/collaboration", "tests/setup.ts"]
}
